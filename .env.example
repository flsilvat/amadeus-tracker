# --- Server ---
PORT=

# --- Automation ---
# Set to "true" to skip driving JFE and return canned sample text instead.
# Useful for developing the parser/storage/API on a non-Windows machine.
DRY_RUN=

# Regex (case-insensitive) used to find the JFE window title.
# Inspect your window's title with Alt+Tab and adjust this if needed.
JFE_WINDOW_TITLE_REGEX=

# Wait (ms) between typing the INITIAL command (AN, LL) and triggering Copy.
# First calls hit the Amadeus server — needs more time to render.
INITIAL_SETTLE_MS=

# Wait (ms) for MD pagination — already-loaded data, much faster.
MD_SETTLE_MS=

# How long (ms) to wait for the clipboard to change after triggering copy.
CLIPBOARD_TIMEOUT_MS=

# Per-keystroke delay used by nut-js. Higher = more reliable typing,
# slightly slower. 100 is a safe default; bump to 150 if you still see
# dropped/leaked keys.
KEYBOARD_AUTO_DELAY_MS=

# --- Scheduler (CURRENTLY DISABLED in src/index.js) ---
# These are read by config.js but not acted on. To re-enable scheduled refresh
# and keepalive Enter, uncomment the scheduler lines in src/index.js.
REFRESH_CRON=
KEEPALIVE_SECONDS=

# --- Storage ---
DB_PATH=

# --- Home airport (used to classify outbound vs inbound) ---
HOME_AIRPORT=

# --- Firestore mirror (phase 2) ---
# Set to "true" once you have a Firebase project and service account file.
FIRESTORE_ENABLED=

# Path to the service-account JSON downloaded from Firebase Console.
# DO NOT commit this file. The .gitignore already excludes service-account.json.
FIREBASE_SERVICE_ACCOUNT_PATH=
