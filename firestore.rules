rules_version = '2';

// Single-user personal tracker. Any authenticated user can read/write
// everything; since you're the only user in your Firebase Auth, that's just
// you. Tighten further by hardcoding your UID once you've signed in once
// and know it — replace the `request.auth != null` checks with
// `request.auth.uid == "YOUR_UID"`.
service cloud.firestore {
  match /databases/{database}/documents {

    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    match /flights/{flightId} {
      allow read, write: if request.auth != null;
    }

    match /observations/{observationId} {
      allow read, write: if request.auth != null;
    }

    // Per-user app state written by the web frontend: favorites, per-pax
    // confirmations, and pass-code overrides. Each signed-in user may read and
    // write ONLY their own document (doc id == their uid).
    match /appState/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Pending command queue (Phase 4). The web app creates command docs; the
    // local service (admin SDK, bypasses rules) flips their status. Clients may
    // create their own pending commands and read status, but never edit them.
    match /commands/{commandId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.status == 'pending'
                    && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // Custom groups: user-curated, cross-trip views (just lists of flight
    // references). Each signed-in user manages their own.
    match /flightGroups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
