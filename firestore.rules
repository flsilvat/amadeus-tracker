rules_version = '2';

// Single-user personal tracker. Any authenticated user can read/write
// everything; since you're the only user in your Firebase Auth, that's just
// you. Tighten further by hardcoding your UID once you've signed in once
// and know it — replace the `request.auth != null` checks with
// `request.auth.uid == "YOUR_UID"`.
service cloud.firestore {
  match /databases/{database}/documents {

    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    match /flights/{flightId} {
      allow read, write: if request.auth != null;
    }

    match /observations/{observationId} {
      allow read, write: if request.auth != null;
    }

    // Per-user app state written by the web frontend: favorites, per-pax
    // confirmations, and pass-code overrides. Each signed-in user may read and
    // write ONLY their own document (doc id == their uid).
    match /appState/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
